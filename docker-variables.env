### ByoCypher settings ##

# Toggle for running database setup on container startup; setting be yes/no
FILL_DB_ON_STARTUP=yes

# Name of database created by BioCypher; Relevant for path to import script => import/$BC_TABLE_NAME/neo4j-admin-import-call.sh
BC_TABLE_NAME=docker

### NEO4j settings ##

# Username for Neo4j database
NEO4J_USER=neo4j

# Password for Neo4j database
NEO4J_PASSWORD=neo4jpassword

# Username and password divided by "/" for Neo4j; Has to match $NEO4J_USER/$NEO4J_PASSWORD
NEO4J_AUTH=neo4j/neo4jpassword

# Variable necessary to use enterprise version of dockerized Neo4j
NEO4J_ACCEPT_LICENSE_AGREEMENT=yes

# Set the default database to 'docker' so you don't have to switch manually
NEO4J_dbms_default__database=docker

NEO4J_PLUGINS=["graph-data-science", "apoc"]

# Combined Security Settings (Comma-separated)
NEO4J_dbms_security_procedures_unrestricted=gds.*,apoc.*
NEO4J_dbms_security_procedures_allowlist=gds.*,apoc.*

# APOC specific settings
NEO4J_apoc_export_file_enabled=true
NEO4J_apoc_import_file_enabled=true
# Memory settings for GDS
NEO4J_dbms_memory_heap_initial_size=2G
NEO4J_dbms_memory_heap_max_size=4G
NEO4J_dbms_memory_pagecache_size=2G
