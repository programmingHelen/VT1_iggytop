"""
inspect_anndata.py
Inspect the AnnData structure to understand chain field names.
Run this first before fixing the main pipeline.
"""
import anndata as ad
import warnings
warnings.filterwarnings("ignore")
 
adata = ad.read_h5ad("data/deduplicated_anndata.h5ad")
 
print("=== obs columns ===")
print(list(adata.obs.columns))
 
print("\n=== obsm keys ===")
print(list(adata.obsm.keys()))
 
print("\n=== First 3 rows of obs ===")
print(adata.obs.head(3))
 
# inspect the airr structure
airr = adata.obsm["airr"]
print(f"\n=== airr type: {type(airr)} ===")
print(f"airr length: {len(airr)}")
 
# look at the first few entries
for i in range(min(5, len(airr))):
    chains = airr[i]
    print(f"\n--- Cell {i} ---")
    print(f"  chains type: {type(chains)}")
    try:
        print(f"  chains length: {len(chains)}")
        for j, chain in enumerate(chains):
            print(f"  chain {j}: type={type(chain)}")
            if chain is not None:
                try:
                    # try to see what fields are available
                    if hasattr(chain, 'keys'):
                        print(f"    keys: {list(chain.keys())}")
                    elif hasattr(chain, '__fields__'):
                        print(f"    fields: {chain.__fields__}")
                    else:
                        print(f"    dir: {[x for x in dir(chain) if not x.startswith('_')]}")
                    # try printing the whole chain
                    print(f"    content: {dict(chain)}")
                except Exception as e:
                    print(f"    error reading chain: {e}")
                    print(f"    repr: {repr(chain)[:200]}")
    except Exception as e:
        print(f"  error: {e}")
        print(f"  repr: {repr(chains)[:300]}")